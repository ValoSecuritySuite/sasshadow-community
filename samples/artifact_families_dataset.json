{
  "dataset_name": "artifact_families_test_dataset",
  "items": [
    {
      "integration_id": "slack_app_manifest",
      "json_data": {
        "display_information": {
          "name": "DataSync Bot",
          "description": "Syncs customer data between CRM and Slack"
        },
        "oauth_config": {
          "scopes": {
            "bot": [
              "channels:read",
              "channels:manage",
              "chat:write",
              "files:write",
              "users:read",
              "users:write",
              "admin"
            ],
            "user": [
              "files:read",
              "users.profile:write"
            ]
          },
          "redirect_urls": [
            "https://app.example.com/oauth/callback"
          ]
        },
        "features": {
          "bot_user": {
            "display_name": "DataSync",
            "always_online": true
          }
        },
        "settings": {
          "event_subscriptions": {
            "request_url": "https://app.example.com/events",
            "bot_events": ["message.channels", "member_joined_channel"]
          }
        }
      },
      "metadata": {}
    },
    {
      "integration_id": "atlassian_connect_descriptor",
      "json_data": {
        "key": "com.example.jira-addon",
        "name": "Project Exporter",
        "description": "Exports Jira data to external warehouse",
        "vendor": { "name": "Example Corp", "url": "https://example.com" },
        "baseUrl": "https://addon.example.com",
        "authentication": { "type": "jwt" },
        "scopes": ["READ", "WRITE", "ACT_AS_USER", "PROJECT_ADMIN"],
        "modules": {
          "webPanels": [
            { "key": "export-panel", "url": "/panel" }
          ]
        },
        "apiMigrations": { "gdpr": true }
      },
      "metadata": {}
    },
    {
      "integration_id": "entra_app_manifest",
      "json_data": {
        "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
        "appId": "11111111-2222-3333-4444-555555555555",
        "displayName": "Enterprise Data Connector",
        "requiredResourceAccess": [
          {
            "resourceAppId": "00000003-0000-0000-c000-000000000000",
            "resourceAccess": [
              { "id": "e1fe6dd8-ba31-4d61-89e7-88639da4683d", "type": "Scope" },
              { "id": "e383f46e-2787-4529-855e-0e479a3ffac0", "type": "Scope" },
              { "id": "863451e7-0667-486c-a5d6-d135439485f0", "type": "Scope" },
              { "id": "e2a3a72e-5f79-4c64-b1b1-878b674786c9", "type": "Scope" },
              { "id": "204e0828-b5ca-4571-a349-6743c2258ba2", "type": "Scope" },
              { "id": "19dbc75e-c2e2-444c-a770-ec596d67c8f0", "type": "Role" }
