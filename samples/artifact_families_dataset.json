    {
      "integration_id": "logic_apps_workflow",
      "json_data": {
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "triggers": {
            "When_a_new_email_arrives": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['office365']['connectionId']"
                  }
                },
                "method": "get",
                "path": "/Mail/OnNewEmail"
              }
            }
          },
          "actions": {
            "Send_to_Slack": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['slack']['connectionId']"
                  }
                },
                "method": "post",
                "path": "/chat.postMessage",
                "body": { "channel": "#alerts", "text": "@triggerBody()?['Subject']" }
              }
            },
            "Store_in_SQL": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['sql']['connectionId']"
                  }
                },
                "method": "post",
                "path": "/datasets/default/tables/emails/items",
                "authentication": {
                  "type": "basic",
                  "password": "SuperSecret123!"
                }
              }
            }
          }
        },
        "parameters": {
          "$connections": {
            "value": {
              "office365": {
                "connectionId": "/subscriptions/xxx/providers/Microsoft.Web/connections/office365",
                "id": "/subscriptions/xxx/providers/Microsoft.Web/locations/eastus/managedApis/office365"
              },
              "slack": {
                "connectionId": "/subscriptions/xxx/providers/Microsoft.Web/connections/slack",
                "id": "/subscriptions/xxx/providers/Microsoft.Web/locations/eastus/managedApis/slack"
              },
              "sql": {
                "connectionId": "/subscriptions/xxx/providers/Microsoft.Web/connections/sql",
                "id": "/subscriptions/xxx/providers/Microsoft.Web/locations/eastus/managedApis/sql"
              }
            }
          }
        },
        "source_app": "office365",
        "destination_app": "slack",
        "data_types": ["pii", "customer_data"]
      },
      "metadata": {}
    },
    {
      "integration_id": "step_functions_workflow",
      "json_data": {
        "Comment": "ETL pipeline: extract from Salesforce, transform, load to Redshift",
        "StartAt": "ExtractFromSalesforce",
        "States": {
          "ExtractFromSalesforce": {
            "Type": "Task",
            "Resource": "arn:aws:lambda:us-east-1:123456789:function:sf-extract",
            "Parameters": {
              "api_key": "sf_live_key_ABCDEFGHIJKLMNOPQRSTUVWXYZ",
              "endpoint": "https://api.salesforce.com/data/v54.0/query"
            },
            "Next": "TransformData"
          },
          "TransformData": {
            "Type": "Task",
            "Resource": "arn:aws:lambda:us-east-1:123456789:function:transform",
            "Next": "LoadToRedshift"
          },
          "LoadToRedshift": {
            "Type": "Task",
            "Resource": "arn:aws:states:::redshift-data:executeStatement",
            "Parameters": {
              "ClusterIdentifier": "my-cluster",
              "Database": "analytics",
              "SecretArn": "arn:aws:secretsmanager:us-east-1:123456789:secret:redshift-creds"
            },
            "End": true
          }
        }
      },
      "metadata": {}
    },
    {
      "integration_id": "n8n_workflow_export",
      "json_data": {
        "name": "CRM to Spreadsheet Sync",
        "nodes": [
          {
            "name": "HubSpot Trigger",
            "type": "n8n-nodes-base.hubspot",
            "parameters": {
              "resource": "contact",
              "operation": "getAll",
              "authentication": "oAuth2"
            },
            "credentials": {
              "hubspotOAuth2Api": { "id": "1", "name": "HubSpot account" }
            }
          },
          {
            "name": "Google Sheets",
            "type": "n8n-nodes-base.googleSheets",
            "parameters": {
              "operation": "append",
              "sheetId": "1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms",
              "secret": "gsheet_write_key_123456789012345678"
            },
            "credentials": {
              "googleSheetsOAuth2Api": { "id": "2", "name": "Google Sheets" }
            }
          },
          {
            "name": "Slack Notification",
            "type": "n8n-nodes-base.slack",
            "parameters": {
              "channel": "#crm-updates",
              "text": "New contacts synced: {{ $json.count }}"
            },
            "credentials": {
              "slackOAuth2Api": { "id": "3", "name": "Slack Bot" }
            }
          }
        ],
        "connections": {
          "HubSpot Trigger": { "main": [[ { "node": "Google Sheets", "type": "main", "index": 0 } ]] },
          "Google Sheets": { "main": [[ { "node": "Slack Notification", "type": "main", "index": 0 } ]] }
        }
      },
      "metadata": {}
    },
    {
      "integration_id": "arm_template_insecure",
      "json_data": {
        "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
        "contentVersion": "1.0.0.0",
        "parameters": {
          "sqlServerPassword": {
            "type": "string",
            "defaultValue": "P@ssw0rd123!"
          },
          "storageAccountKey": {
            "type": "string",
            "defaultValue": "abc123DEF456ghi789JKL012mno345PQR678stu901VWX234yz"
          },
          "appName": {
            "type": "string",
            "defaultValue": "myapp"
          }
        },
        "resources": [
          {
            "type": "Microsoft.Sql/servers",
            "apiVersion": "2021-11-01",
            "name": "[parameters('appName')]",
            "location": "[resourceGroup().location]",
            "properties": {
              "administratorLogin": "sqladmin",
              "administratorLoginPassword": "[parameters('sqlServerPassword')]"
            }
          }
        ],
        "source_app": "azure_sql",
        "destination_app": "azure_storage",
        "data_types": ["credentials", "customer_data"]
      },
      "metadata": {}
    }
  ]
}
