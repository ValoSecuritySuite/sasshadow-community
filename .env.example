# SaaSShadow Community Edition - environment configuration
#
# Copy to .env and adjust as needed. All variables are optional; the
# defaults below match the in-code defaults. Enterprise-only modules
# (remediation, correlation, SaaS mapping, playbooks, reporting
# automation, learning loop, custom report branding) are not part of
# this build and cannot be enabled via configuration.

# Build edition. Fixed to "community" for this repository.
APP_EDITION=community

# Path to the YAML rules file used by the scan pipeline.
APP_RULES_PATH=app/rules/default_yml_rule.yml

# Logging level: DEBUG | INFO | WARNING | ERROR
APP_LOG_LEVEL=INFO

# Default API rate limit (slowapi syntax, e.g. "100/minute").
APP_RATE_LIMIT=100/minute

# Seconds to cache parsed rules in memory (0 disables caching).
APP_RULES_CACHE_TTL_SECONDS=60

# SQLite database path for scan history (created automatically).
APP_SCAN_HISTORY_DB=data/scans.db

# Basic dashboard
APP_DASHBOARD_ENABLED=true
APP_DASHBOARD_CACHE_TTL_SECONDS=30
APP_DASHBOARD_DEFAULT_WINDOW=7d
