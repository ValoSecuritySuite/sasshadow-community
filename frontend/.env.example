# API base URL for the SaaSShadow backend (no trailing slash).
# Used by the frontend for health, rules, scan, dataset, and plugins.
#
# Local dev (backend on same machine):
#   NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# Or leave unset to use the default: http://127.0.0.1:8000
#
# Production: set to your deployed backend URL, e.g.:
#   NEXT_PUBLIC_API_URL=https://api.yourdomain.com
#
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
